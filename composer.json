{
    "name": "adampatterson/http",
    "description": "A simple Guzzle wrapper",
    "keywords": [
        "http",
        "guzzle"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Adam Patterson",
            "email": "hello@adampatterson.ca"
        }
    ],
    "support": {
        "issues": "https://github.com/adampatterson/http/issues",
        "source": "https://github.com/adampatterson/http"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "psy/psysh": "^0.12.22",
        "symfony/var-dumper": "^8.0",
        "spatie/ray": "^1.48",
        "laravel/pint": "^1.29"
    },
    "require": {
        "guzzlehttp/guzzle": "^7.4",
        "illuminate/collections": "^v11.6.0"
    },
    "autoload": {
        "psr-4": {
            "Http\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Http\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:warnings": "phpunit --display-warnings",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage:build": "XDEBUG_MODE=coverage phpunit --coverage-html build/coverage",
        "pint": "pint",
        "pint:test": "pint --test",
        "pint:dirty": "pint --dirty",
        "example:auth:basic": "php examples/auth-basic.php",
        "example:auth:bearer": "php examples/auth-bearer.php",
        "example:get": "php examples/get.php",
        "example:post": "php examples/post.php",
        "example:post:headers": "php examples/post-headers.php",
        "example:post:json": "php examples/post-json.php",
        "example:post:form": "php examples/post-form.php",
        "example:put": "php examples/put.php",
        "example:patch": "php examples/patch.php",
        "example:delete": "php examples/delete.php",
        "example:cookie": "php examples/cookie.php",
        "example:cookie:jar": "php examples/cookie-jar.php",
        "example:timeout": "php examples/timeout.php",
        "example:timeout:fail": "php examples/timeout.php fail",
        "example:retry": "php examples/retry.php",
        "example:retry:fail": "php examples/retry.php fail"
    },
    "holder": {
        "examples": [
            "@example:auth:basic",
            "@example:auth:bearer",
            "@example:get",
            "@example:post",
            "@example:post:headers",
            "@example:post:json",
            "@example:post:form",
            "@example:put",
            "@example:patch",
            "@example:delete",
            "@example:cookie",
            "@example:cookie:jar",
            "@example:timeout",
            "@example:timeout:fail",
            "@example:retry",
            "@example:retry:fail"
        ],
        "example:multiple": "php examples/multiple.php",
        "example:preload-aliases": "php examples/preload-aliases.php",
        "example:proxy": "php examples/proxy.php",
        "example:session": "php examples/session.php"
    }
}
